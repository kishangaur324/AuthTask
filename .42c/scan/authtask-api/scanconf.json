    "customizations": {
        "happyPaths": {
            "retry": 1,
            "responsePolicy": {
                "httpStatusExpected": true,
                "mustBeConformant": true
            },
            "httpStatusExpected": [
                "2XX",
                "404"
            ]
        },
        "tests": {
            "responsePolicy": {
                "httpStatusExpected": true,
                "mustBeConformant": true
            }
        },
        "requests": {}
    },
